{
  "name": "@pwqa-fixture/sample-pw-allure-project",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.8.0",
  "scripts": {
    "list": "playwright test --list --reporter=json",
    "test:allure": "playwright test --reporter=allure-playwright",
    "allure:generate": "allure generate ./allure-results -o ./allure-report",
    "allure:quality-gate": "allure quality-gate ./allure-results"
  },
  "devDependencies": {
    "@playwright/test": "^1.55.0",
    "allure": "~3.6.2",
    "allure-playwright": "~3.7.1"
  }
}
