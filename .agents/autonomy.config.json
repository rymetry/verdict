{
  "version": 1,
  "workflow": {
    "preset": "default",
    "stages": ["think", "plan", "build", "qa-only", "review", "ship", "learn"],
    "includeDesignReview": false
  },
  "adapters": {
    "taskSource": "custom-command",
    "executor": "codex",
    "verifier": "verdict-verify-completion",
    "reviewer": "codex-review",
    "publisher": "github-pr"
  },
  "taskSources": {
    "customCommand": {
      "command": ["node", ".agents/scripts/pick-verdict-plan-v3.mjs"]
    }
  },
  "reviewers": {
    "customCommands": [
      {
        "name": "diff-review",
        "command": ["node", "packages/autonomy/dist/review-cli.js", "--pr", "{prNumber}"],
        "expectedReviewers": ["diff-review"],
        "timeoutMs": 60000
      }
    ]
  },
  "safety": {
    "autoMerge": false,
    "highRiskPatterns": [
      "auth",
      "permission",
      "billing",
      "payment",
      "delete",
      "external integration",
      "deploy"
    ],
    "maxFailuresPerTask": 3
  }
}
