{
  "name": "playwright-workbench",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.8.0",
  "scripts": {
    "dev": "pnpm --filter '@pwqa/*' --parallel dev",
    "dev:agent": "pnpm --filter @pwqa/agent dev",
    "dev:web": "pnpm --filter @pwqa/web dev",
    "build": "pnpm --filter '@pwqa/*' --filter @rymetry/agent-autonomy build",
    "typecheck": "pnpm --filter @pwqa/shared build && pnpm --filter '@pwqa/*' --filter @rymetry/agent-autonomy typecheck && pnpm --filter @pwqa/agent typecheck:test",
    "test": "pnpm --filter '@pwqa/*' --filter @rymetry/agent-autonomy test",
    "e2e": "pnpm --filter @pwqa-e2e/workbench-gui e2e",
    "e2e:allure": "pnpm --filter @pwqa-e2e/workbench-gui e2e:allure",
    "smoke:gui": "pnpm --filter @pwqa-e2e/workbench-gui smoke",
    "smoke:gui:allure": "pnpm --filter @pwqa-e2e/workbench-gui smoke:allure",
    "agents:drive": "pnpm --filter @rymetry/agent-autonomy run drive --",
    "agents:init": "pnpm --filter @rymetry/agent-autonomy run init --",
    "agents:progress": "pnpm --filter @rymetry/agent-autonomy run progress --"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "typescript": "^5.9.3"
  }
}
