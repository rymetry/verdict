    "start": "node dist/server.js"
  },
  "dependencies": {
    "@fastify/cors": "^11.1.0",
    "@pwqa/shared": "workspace:*",
    "fastify": "^5.6.2",
    "pino": "^10.1.0",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "typescript": "^5.9.3"
  }
}
